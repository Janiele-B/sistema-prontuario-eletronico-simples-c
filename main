#include <stdio.h>
#include <string.h>
#include <locale.h>

int main() {

    setlocale(LC_ALL, "Portuguese");
    // Declarando as variáveis
    char nome[1000][30], data_nasc[1000][15];
    char busca[20], CPF[1000][20]; // formato xxx.xxx.xxx-xx
    int idade[1000], resposta, i = 0, Pacientes = 0, encontrado,D;
    char Sexo[1000]; // M ou F
    char contato[1000][20]; // formato (xx)xxxxx-xxxx
    char historico[1000][100],exames[1000][100], data[1000][15]; 
    char resultado[1000][100], observacao[1000][100], recomendacao[1000][100],continuar, vontade;

    do {
        printf("------------------------------\n");
        printf("PRONTUARIO ELETRONICO\n");
        printf("------------------------------\n");
        printf("\nMENU:\n");
        printf("1- Cadastrar um novo Prontuario\n");
        printf("2- Listar todos os Prontuarios\n");
        printf("3- Buscar um Prontuario\n");
        printf("4- Alterar Prontuario existente\n");
        printf("5- Remover Prontuario\n");
        printf("6- Sair\n");
        printf("------------------------------\n");

        printf("\nO que deseja fazer no sistema? (Insira o numero que acompanha a opcao que deseja.)");
        scanf("%d", &resposta);
        getchar(); // Limpar o buffer do teclado

        switch (resposta) {
            case 1:
            //cadastrando um novo prontuario
            do{
                printf("------------------------------\n");
                printf("\nCadastro de novo prontuario\n");
                printf("------------------------------\n");

                printf("Nome do Paciente:");
                fgets(nome[Pacientes], sizeof(nome[Pacientes]), stdin);
                nome[Pacientes][strcspn(nome[Pacientes], "\n")] = '\0';

                printf("CPF (xxx.xxx.xxx-xx):");
                fgets(CPF[Pacientes], sizeof(CPF[Pacientes]), stdin);
                CPF[Pacientes][strcspn(CPF[Pacientes], "\n")] = '\0';

                printf("Data de nascimento (dd/mm/aaaa):");
                fgets(data_nasc[Pacientes], sizeof(data_nasc[Pacientes]), stdin);
                data_nasc[Pacientes][strcspn(data_nasc[Pacientes], "\n")] = '\0';

                printf("Idade:");
                scanf("%d", &idade[Pacientes]);
                getchar();

                printf("Sexo (M/F):");
                scanf("%c", &Sexo[Pacientes]);
                getchar();

                printf("Telefone para contato (xx)xxxxx-xxxx:");
                fgets(contato[Pacientes], sizeof(contato[Pacientes]), stdin);
                contato[Pacientes][strcspn(contato[Pacientes], "\n")] = '\0';

                printf("Historico medico:");
                fgets(historico[Pacientes], sizeof(historico[Pacientes]), stdin);
                historico[Pacientes][strcspn(historico[Pacientes], "\n")] = '\0';

                printf("Exames realizados:");
                fgets(exames[Pacientes], sizeof(exames[Pacientes]), stdin);
                exames[Pacientes][strcspn(exames[Pacientes], "\n")] = '\0';

                printf("Data da realizacao dos exames:");
                fgets(data[Pacientes], sizeof(data[Pacientes]), stdin);
                data[Pacientes][strcspn(data[Pacientes], "\n")] = '\0';

                printf("Resultado dos exames:");
                fgets(resultado[Pacientes], sizeof(resultado[Pacientes]), stdin);
                resultado[Pacientes][strcspn(resultado[Pacientes], "\n")] = '\0';

                printf("Observacao:");
                fgets(observacao[Pacientes], sizeof(observacao[Pacientes]), stdin);
                observacao[Pacientes][strcspn(observacao[Pacientes], "\n")] = '\0';

                printf("Recomendacao medica:");
                fgets(recomendacao[Pacientes], sizeof(recomendacao[Pacientes]), stdin);
                recomendacao[Pacientes][strcspn(recomendacao[Pacientes], "\n")] = '\0';

                // Incrementando o contador de pacientes
                Pacientes++;

                printf("\nProntuário cadastrado com sucesso!\n");

                //Perguntando se o usúario deseja continuar a realizar a opção esolhida anteriormente
                printf("\nDeseja cadastrar um novo prontuario? (S/N): ");
                scanf(" %c", &continuar);
                getchar();
            }while( continuar == 'S' || continuar == 's');
            break;

            case 2:
            //imprimindo a lista de prontuarios cadastrados
                printf("------------------------------\n");
                printf("\nLISTA DE PRONTUARIOS:\n");
                printf("------------------------------\n");
                if (Pacientes == 0) {
                    printf("Nenhum prontuario cadastrado.\n");
                }
                for (i = 0; i < Pacientes; i++) {
                    printf("\n------------------------------\n");
                    printf("Nome do paciente: %s\n", nome[i]);
                    printf("CPF: %s\n", CPF[i]);
                    printf("Data de nascimento: %s\n", data_nasc[i]);
                    printf("Idade: %d\n", idade[i]);
                    printf("Sexo: %c\n", Sexo[i]);
                    printf("Contato: %s\n", contato[i]);
                    printf("Historico medico: %s\n", historico[i]);
                    printf("Exames realizados: %s\n", exames[i]);
                    printf("Data da realizacao dos exames: %s\n", data[i]);
                    printf("Resultado dos exames: %s\n", resultado[i]);
                    printf("Observacao: %s\n", observacao[i]);
                    printf("Recomendacao medica: %s\n", recomendacao[i]);
                    printf("------------------------------\n");
                }
                break;

            case 3:
            //buscando prontuario e imprimindo na tela
            do{
                printf("------------------------------\n");
                printf("\nBUSCANDO PRONTUARIO\n");
                printf("------------------------------\n");
                encontrado = 0;
    
                printf("Digite o CPF do paciente que deseja encontrar o prontuario (xxx.xxx.xxx-xx): ");
                scanf(" %s", &busca);
                getchar();

                for(i=0; i< Pacientes; i++){  
                    if(strcmp(busca, CPF[i]) == 0){
                        printf("\n------------------------------\n");
                        printf("Nome do paciente: %s\n", nome[i]);
                        printf("CPF: %s\n", CPF[i]);
                        printf("Data de nascimento: %s\n", data_nasc[i]);
                        printf("Idade: %d\n", idade[i]);
                        printf("Sexo: %c\n", Sexo[i]);
                        printf("Contato: %s\n", contato[i]);
                        printf("Historico medico: %s\n", historico[i]);
                        printf("Exames realizados: %s\n", exames[i]);
                        printf("Data da realizacao dos exames: %s\n", data[i]);
                        printf("Resultado dos exames: %s\n", resultado[i]);
                        printf("Observacao: %s\n", observacao[i]);
                        printf("Recomendacao medica: %s\n", recomendacao[i]);
                        printf("------------------------------\n");
                        encontrado = 1;
                    }
                }
                if(encontrado == 0){
                    printf("Prontuario nao cadastrado no sistema!");
                }
                //Perguntando se o usúario deseja continuar a realizar a opção esolhida anteriormente
                printf("\nDeseja buscar outro prontuario? (S/N): ");
                scanf(" %c", &continuar);
                getchar();

            }while( continuar == 'S' || continuar == 's');
            break;

            case 4:
            //alterar um prontuario existente
            do{
                printf("------------------------------\n");
                printf("\n ALTERANDO PRONTUARIO\n");
                printf("------------------------------\n");
                printf("Digite o CPF do paciente que deseja encontrar o prontuario para alterar as informacoes (xxx.xxx.xxx-xx): ");
                scanf(" %s", &busca);
                encontrado = 0;

                for(i=0; i< Pacientes; i++){
                    if(strcmp(busca, CPF[i]) == 0){
                        encontrado = 1;
                        printf("\n------------------------------\n");
                        printf("\nNome do paciente: %s\n", nome[i]);
                        printf("Deseja alterar o nome do paciente? (S/N)");
                        scanf(" %c", &vontade);
                        getchar();
                        if( vontade == 'S' || vontade == 's'){
                            printf("Digite o novo nome do Paciente:");
                            fgets(nome[i], sizeof(nome[i]), stdin);
                            nome[i][strcspn(nome[i], "\n")] = '\0';
                        }

                        printf("\nCPF: %s\n", CPF[i]);
                        printf("Deseja alterar o CPF do paciente? (S/N)");
                        scanf(" %c", &vontade);
                        getchar();
                        if( vontade == 'S' || vontade == 's'){
                            printf("Digite o novo CPF do Paciente:");
                            fgets(CPF[i], sizeof(CPF[i]), stdin);
                            CPF[i][strcspn(CPF[i], "\n")] = '\0';
                        }

                        printf("\nData de nascimento: %s\n", data_nasc[i]);
                        printf("Deseja alterar a data de nascimento do paciente? (S/N)");
                        scanf(" %c", &vontade);
                        getchar();
                        if( vontade == 'S' || vontade == 's'){
                            printf("Digite a nova data de nascimento do Paciente:");
                            fgets(data_nasc[i], sizeof(data_nasc[i]), stdin);
                            data_nasc[i][strcspn(data_nasc[i], "\n")] = '\0';
                        }

                        printf("\nIdade: %d\n", idade[i]);
                        printf("Deseja alterar a idade do paciente? (S/N)");
                        scanf(" %c", &vontade);
                        getchar();
                        if( vontade == 'S' || vontade == 's'){
                            printf("Digite a nova idade do Paciente:");
                            scanf(" %d", &idade[i]);
                        }
                        printf("\nSexo: %c\n", Sexo[i]);
                        printf("Deseja alterar o sexo do paciente? (S/N)");
                        scanf(" %c", &vontade);
                        getchar();
                        if( vontade == 'S' || vontade == 's'){
                            printf("Digite o novo sexo do Paciente:");
                            scanf(" %s", &Sexo[i]);
                        }
                        printf("\nContato: %s\n", contato[i]);
                        printf("Deseja alterar o contato do paciente? (S/N)");
                        scanf(" %c", &vontade);
                        getchar();
                        if( vontade == 'S' || vontade == 's'){
                            printf("Digite o novo contato do Paciente:");
                            fgets(contato[i], sizeof(contato[i]), stdin);
                            contato[i][strcspn(contato[i], "\n")] = '\0';
                        }
                        printf("\nHistórico médico: %s\n", historico[i]);
                        printf("Deseja alterar o historico medico do paciente? (S/N)");
                        scanf(" %c", &vontade);
                        getchar();
                        if( vontade == 'S' || vontade == 's'){
                            printf("Digite o novo historico medico do paciente:");
                            fgets(historico[i], sizeof(historico[i]), stdin);
                            historico[i][strcspn(historico[i], "\n")] = '\0';
                        }
                        printf("\nExames realizados: %s\n", exames[i]);
                        printf("Deseja alterar os exames realizados do paciente? (S/N)");
                        scanf(" %c", &vontade);
                        getchar();
                        if( vontade == 'S' || vontade == 's'){
                            printf("Digite os novos exames realizados pelo paciente:");
                            fgets(exames[i], sizeof(exames[i]), stdin);
                            exames[i][strcspn(exames[i], "\n")] = '\0';
                        }
                        printf("\nData da realizacao dos exames: %s\n", data[i]);
                        printf("Deseja alterar a data de realizacao dos exames do paciente? (S/N)");
                        scanf(" %c", &vontade);
                        getchar();
                        if( vontade == 'S' || vontade == 's'){
                            printf("Digite a nova data de realizacao dos exames do paciente:");
                            fgets(data[i], sizeof(data[i]), stdin);
                            data[i][strcspn(data[i], "\n")] = '\0';
                        }
                        printf("\nResultado dos exames: %s\n", resultado[i]);
                        printf("Deseja alterar o resultado dos exames do paciente? (S/N)");
                        scanf(" %c", &vontade);
                        getchar();
                        if( vontade == 'S' || vontade == 's'){
                            printf("Digite os novos resultados dos exames do paciente:");
                            fgets(resultado[i], sizeof(resultado[i]), stdin);
                            resultado[i][strcspn(resultado[i], "\n")] = '\0';
                        }
                        printf("\nObservacao: %s\n", observacao[i]);
                        printf("Deseja alterar as observacoes? (S/N)");
                        scanf(" %c", &vontade);
                        getchar();
                        if( vontade == 'S' || vontade == 's'){
                            printf("Digite a nova observacao:");
                            fgets(observacao[i], sizeof(observacao[i]), stdin);
                            observacao[i][strcspn(observacao[i], "\n")] = '\0';
                        }
                        printf("\nRecomendacao medica: %s\n", recomendacao[i]);
                        printf("Deseja alterar as recomendacoes? (S/N)");
                        scanf(" %c", &vontade);
                        getchar();
                        if( vontade == 'S' || vontade == 's'){
                            printf("Digite as novas recomendacoes:");
                            fgets(recomendacao[i], sizeof(recomendacao[i]), stdin);
                            recomendacao[i][strcspn(recomendacao[i], "\n")] = '\0';
                        }
                        printf("------------------------------\n");
                    }
                }
                if( encontrado == 0){
                    printf("Nao foi encontrado nenhum prontuario cadastrado com este CPF.");
                }

                //Perguntando se o usúario deseja continuar a realizar a opção esolhida anteriormente
                printf("\nDeseja buscar outro prontuario? (S/N): ");
                scanf(" %c", &continuar);
                getchar();
            }while( continuar == 'S' || continuar == 's');
            break;

            case 5:
            //removendo prontuário
            do{
                printf("------------------------------\n");
                printf("\n REMOVENDO PRONTUARIO\n");
                printf("------------------------------\n");
                printf("Digite o CPF do paciente que deseja encontrar o prontuario para remover(xxx.xxx.xxx-xx): ");
                scanf(" %s", &busca);

                for(i=0; i< Pacientes; i++){
                    if(strcmp(busca, CPF[i]) == 0){
                        encontrado = 1;
                        //removendo o prontuário deslocando os dados
                        for(D = 0; D < Pacientes - 1; D++){
                            strcpy(nome[D], nome[D + 1]);
                            strcpy(CPF[D], CPF[D + 1]);
                            strcpy(data_nasc[D], data_nasc[D + 1]);
                            idade[D], idade[D + 1];
                            Sexo[D], Sexo[D + 1];
                            strcpy(contato[D], contato[D + 1]);
                            strcpy(historico[D], historico[D + 1]);
                            strcpy(exames[D], exames[D + 1]);
                            strcpy(data[D], data[D + 1]);
                            strcpy(resultado[D], resultado[D + 1]);
                            strcpy(observacao[D], observacao[D + 1]);
                            strcpy(recomendacao[D], recomendacao[D + 1]);
                        }
                    }
                }
                Pacientes --;
                printf("\nProntuario removido com sucesso!\n");
                break;

                if(encontrado == 0){
                    printf("Nao foi encontrado nenhum prontuario cadastrado com este CPF.");
                }

                //Perguntando se o usúario deseja continuar a realizar a opção esolhida anteriormente
                printf("\nDeseja remover outro prontuario? (S/N): ");
                scanf(" %c", &continuar);
                getchar();
            }while(continuar == 'S' || continuar == 's');
            break;

            case 6:
            //encerrando o sistema
            printf("O sistema sera encerrado. (Tecle enter para prosseguir)");
            getchar();
            break;
            
            default:
                printf("Opcao invalida!\n");
                break;
        }

    } while (resposta != 6);

    return 0;
}
